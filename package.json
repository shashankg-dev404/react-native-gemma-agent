{
  "name": "react-native-gemma-agent",
  "version": "0.2.1",
  "description": "React Native SDK for on-device AI agents powered by Google Gemma 4",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./ai": {
      "react-native": "./src/ai/index.ts",
      "types": "./lib/ai/index.d.ts",
      "default": "./lib/ai/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "skills",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "gemma",
    "on-device-ai",
    "llm",
    "agent",
    "skills",
    "llama.rn"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shashankg-dev404/react-native-gemma-agent"
  },
  "author": "Shashank Gupta",
  "license": "MIT",
  "peerDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "llama.rn": ">=0.12.0-rc.3",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-fs": ">=2.20.0",
    "react-native-webview": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/provider": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  }
}
