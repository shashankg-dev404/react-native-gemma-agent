{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2020"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./lib/typescript",
    "rootDir": "./src",
    "noEmit": true,
    "paths": {
      "react-native-gemma-agent": ["./src/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "example"]
}
